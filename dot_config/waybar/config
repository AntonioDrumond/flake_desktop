{
    "layer": "overlay",
        "position": "top",
        "margin-bottom": -10,
        "spacing" : 0,

        "modules-left": [
            "hyprland/workspaces",
            "cpu",
            "memory"
        ],

        "modules-center": ["clock"],

        "modules-right": [
            "custom/coffee",
            "pulseaudio", 
        ],

        "hyprland/workspaces": {
            "format": "{name}: {icon}",
            "format-icons": {
                "active": "п†’",
                "default": "п„‘"
            }
        },

        "backlight": {
            // "format": "{icon}",
            "format": "{icon} : {percent}%",
            "format-icons": ["оЋЌ","у°ѓњ", "у°ѓ›", "у°ѓћ","у°ѓќ","у°ѓџ","у°ѓ "],
            "tooltip-format": "{percent}%"
        },

        "bluetooth": {
            "format": "у°‚І",
            "format-on": "{icon}",
            "format-off": "{icon}", 
            "format-connected":"{icon}",
