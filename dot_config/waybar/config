            // "format-full": "",
            "format-icons": ["у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°‚Ђ", "у°Ѓ№"],
            //"on-click": "kitty --class \"auto-cpufreq\" sudo auto-cpufreq --monitor"
