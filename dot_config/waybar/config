        "clock": {
            "timezone": "America/Sao_Paulo",
            "tooltip": false,
            "format": "{:%A %d - %H:%M}",
            "interval": 1,
            "on-click": "kitty --class \"cal\" /home/antonio/.config/waybar/cal",
        },

        "network": {
            "format-wifi": "у°¤ў",
