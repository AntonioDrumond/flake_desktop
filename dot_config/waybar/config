            "on-click": "kitty --class \"nmtui\" nmtui"
        },

        "cpu": {
            "interval": 5,
            "format": "п‹› {usage:>2}%",
            "on-click": "kitty --class \"btop\" btop -p 1"
        },

        "memory": {
            "interval": 5,
            "format": "ої…  {used:0.1f}/{total:0.1f}",
            "tooltip-format": "Memory",
            "on-click": "kitty --class \"btop\" btop -p 2"
        },

        "pulseaudio": {
            "format": "{icon} {volume}%",
            "format-muted": "о»Ё",
            "format-icons": {
                "default": ["пЂ¦", "пЂ§", "пЂЁ "]
